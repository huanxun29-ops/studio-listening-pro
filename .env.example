# ============================================================
# 可选：配置 Firebase 即可启用「云端同步」（多设备共享单词本）。
# 不配置则默认使用浏览器本地存储（localStorage），clone 后直接能跑。
# ------------------------------------------------------------
# 把整段 Firebase config 压成一行 JSON 填进来：
# VITE_FIREBASE_CONFIG={"apiKey":"xxx","authDomain":"xxx.firebaseapp.com","projectId":"xxx","storageBucket":"xxx","messagingSenderId":"xxx","appId":"xxx"}
# ============================================================
VITE_FIREBASE_CONFIG=
VITE_APP_ID=studio-pro
